{
  "manifest_version": 3,
  "name": "CRYPTA Password Manager",
  "version": "1.0",
  "description": "Ultra-secure self-hosted password manager. Zero-knowledge, AES-256 encrypted.",
  "permissions": ["storage", "activeTab", "scripting", "tabs"],
  "action": {
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
